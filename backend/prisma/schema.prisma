generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// Enums
// ------------------------------------------------------

enum Sex {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MealQuality {
  BALANCED
  JUNK
  SKIPPED
}

enum ActivityType {
  WALK
  GYM
  SPORTS
  NONE
}

enum StressLevel {
  LOW
  MODERATE
  HIGH
}

enum LifestyleStatus {
  BALANCED
  NEEDS_IMPROVEMENT
  UNHEALTHY_PATTERN_DETECTED
}

enum ArticleCategory {
  NUTRITION
  SLEEP_HYGIENE
  STRESS_MANAGEMENT
  EXERCISE
  EARLY_SIGNS
}

// ------------------------------------------------------
// Profile (Mapped to Supabase Auth)
// ------------------------------------------------------

model Profile {
  id             String   @id @default(uuid()) @db.Uuid // Matches Supabase auth.users.id
  email          String   @unique
  nickname       String
  yearLevel      String
  section        String?
  age            Int
  sex            Sex
  healthConcerns String[] // Optional chips stored as array of strings
  pushToken      String? // For Expo Notifications
  currentStreak  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs     Log[]
  patterns PatternResult[]
}

// ------------------------------------------------------
// Daily Lifestyle Logging
// ------------------------------------------------------

model Log {
  id     String   @id @default(uuid()) @db.Uuid
  userId String   @db.Uuid
  date   DateTime @db.Date // Ensures one log per calendar day

  // Step 1: Sleep
  sleptAt    DateTime
  wokeUp     DateTime
  sleepHours Float

  // Step 2: Food
  breakfast MealQuality
  lunch     MealQuality
  dinner    MealQuality
  waterCups Int

  // Step 3: Activity
  activityDuration Int // in minutes (0-120)
  activityType     ActivityType[] // Allows multiple selections

  // Step 4: Screen time
  studyHours      Float
  screenTimeHours Float

  // Step 5: Stress
  stressLevel StressLevel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile       Profile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  patternResult PatternResult?

  @@unique([userId, date]) // Enforces FR-03-2: one log entry per user per calendar day
}

// ------------------------------------------------------
// Pattern Detection Engine
// ------------------------------------------------------

model PatternResult {
  id     String   @id @default(uuid()) @db.Uuid
  userId String   @db.Uuid
  logId  String   @unique @db.Uuid // 1:1 relation with DailyLog
  date   DateTime @db.Date

  lifestyleStatus LifestyleStatus

  // Specific patterns detected based on rule thresholds
  activePatterns String[]

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  log     Log     @relation(fields: [logId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// Health Guidance Library
// ------------------------------------------------------

model Article {
  id       String          @id @default(uuid()) @db.Uuid
  title    String
  category ArticleCategory
  preview  String
  content  String          @db.Text
  readTime Int // in minutes
  featured Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
